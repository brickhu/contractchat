# ── AI 服务 ──────────────────────────────────
ANTHROPIC_KEY=sk-ant-...
DEEPSEEK_KEY=sk-...         # 可选

# ── 链上数据 ──────────────────────────────────
ETHERSCAN_KEY=...            # 可选，用于自动获取合约 ABI

# ── 运营后台 ──────────────────────────────────
ADMIN_PASSWORD=your-strong-password
ADMIN_JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ── 数据存储 ──────────────────────────────────
DATA_DIR=./data              # SQLite 数据目录，Railway 会自动持久化

# ── 服务端口 ──────────────────────────────────
PORT=3001
